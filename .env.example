# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────
# MONGODB ATLAS
# ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/riserank?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────
# BCRYPT
# ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─────────────────────────────────────────────
# CORS — comma-separated allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://riserank.in,https://www.riserank.in

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ─────────────────────────────────────────────
# EMAIL (Nodemailer — Gmail SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# ─────────────────────────────────────────────
# AWS S3 (for image uploads)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=riserank-assets

# ─────────────────────────────────────────────
# FIREBASE (push notifications)
# ─────────────────────────────────────────────
# FIREBASE_SERVER_KEY=

# ─────────────────────────────────────────────
# SUPER ADMIN SEED (used by scripts/seedSuperAdmin.js only)
# ─────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@riserank.in
SUPER_ADMIN_PASSWORD=RiseRank@2024

# ─────────────────────────────────────────────
# REDIS (optional — for future rate limit / cache)
# ─────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379


# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────
# Web client ID from Google Cloud Console (used for server-side token verification)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_web_client_id_here
