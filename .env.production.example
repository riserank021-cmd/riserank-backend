# ═══════════════════════════════════════════════════════════════════════════
# RiseRank Backend — PRODUCTION Environment Variables
# Copy this file to .env on your EC2 server and fill every value
# Run `bash scripts/preflight.sh` to validate before deploying
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/riserank?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_random_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_different_from_JWT_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://riserank.in,https://www.riserank.in,https://admin.riserank.in

# ── Security ─────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Email / SMTP ──────────────────────────────────────────────────────────
# Gmail: Enable 2FA → https://myaccount.google.com/apppasswords → create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# ── AWS S3 ────────────────────────────────────────────────────────────────
# IAM user needs: s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket
# Create bucket at: https://s3.console.aws.amazon.com
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=riserank-assets
AWS_S3_BASE_URL=https://riserank-assets.s3.ap-south-1.amazonaws.com

# ── Firebase FCM ──────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# The private key must keep its \n newlines — wrap in double quotes
FIREBASE_PROJECT_ID=riserank-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@riserank-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvA...\n-----END PRIVATE KEY-----\n"

# ── Google OAuth ──────────────────────────────────────────────────────────
# Web Client ID from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── App Version Gate ──────────────────────────────────────────────────────
# Must match APP_VERSION in riserank-app/src/utils/constants.ts
MINIMUM_APP_VERSION=1.0.0
LATEST_APP_VERSION=1.0.0
MAINTENANCE_MODE=false

# ── Super Admin Seed ──────────────────────────────────────────────────────
# Only used by: node scripts/seedSuperAdmin.js  (run ONCE after first deploy)
SUPER_ADMIN_EMAIL=superadmin@riserank.in
SUPER_ADMIN_PASSWORD=RiseRank@SuperAdmin2024!
