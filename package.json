{
  "name": "riserank-backend",
  "version": "1.0.0",
  "description": "RiseRank - Bilingual Government Exam Preparation Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop riserank-backend",
    "restart:pm2": "pm2 restart riserank-backend",
    "logs:pm2": "pm2 logs riserank-backend",
    "seed:superadmin": "node scripts/seedSuperAdmin.js"
  },
  "keywords": [
    "riserank",
    "exam",
    "preparation",
    "ssc",
    "banking",
    "railway"
  ],
  "author": "RiseRank",
  "license": "ISC",
